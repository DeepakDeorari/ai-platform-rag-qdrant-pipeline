from qdrant_client import QdrantClient
from sentence_transformers import SentenceTransformer
import requests

# ----------------------------
# Configuration
# ----------------------------

COLLECTION_NAME = "knowledge"
MODEL_NAME = "BAAI/bge-small-en-v1.5"
OLLAMA_MODEL = "phi3"

# Minimum score required to answer
MIN_SCORE = 0.5

# ----------------------------
# Connect Qdrant
# ----------------------------

client = QdrantClient(
    host="localhost",
    port=6333,
)

# ----------------------------
# Embedding Model
# ----------------------------

embedder = SentenceTransformer(
    MODEL_NAME
)

# ----------------------------
# User Question
# ----------------------------

question = input("Question: ").strip()

if not question:
    print("Please enter a question.")
    exit(1)

# ----------------------------
# Embed Question
# ----------------------------

query_vector = embedder.encode(
    question
).tolist()

# ----------------------------
# Retrieve Documents
# ----------------------------

results = client.query_points(
    collection_name=COLLECTION_NAME,
    query=query_vector,
    limit=3,
).points

# ----------------------------
# No Results
# ----------------------------

if not results:
    print("\nNo documents found.")
    exit(0)

# ----------------------------
# Relevance Threshold
# ----------------------------

if results[0].score < MIN_SCORE:
    print("\nNo relevant information found in knowledge base.")
    print(f"Best score: {results[0].score:.4f}")
    exit(0)

# ----------------------------
# Show Retrieved Chunks
# ----------------------------

print("\nRetrieved Chunks:\n")

for hit in results:
    print(f"Source: {hit.payload.get('source', 'unknown')}")
    print(f"Score : {hit.score:.4f}")
    print(hit.payload["text"][:200])
    print("-" * 60)

# ----------------------------
# Build Context
# ----------------------------

context = "\n\n".join(
    hit.payload["text"]
    for hit in results
)

# ----------------------------
# Build Prompt
# ----------------------------

prompt = f"""
You are a helpful assistant.

Rules:
- Answer using ONLY the provided context.
- If the answer is not present in the context, say:
  "I don't know based on the provided documents."
- Keep the answer concise.

Context:
{context}

Question:
{question}

Answer:
"""

# ----------------------------
# Ask Ollama
# ----------------------------

response = requests.post(
    "http://localhost:11434/api/generate",
    json={
        "model": OLLAMA_MODEL,
        "prompt": prompt,
        "stream": False,
    },
)

response.raise_for_status()

answer = response.json()["response"]

# ----------------------------
# Show Answer
# ----------------------------

print("\nAnswer:\n")
print(answer)

# ----------------------------
# Show Sources
# ----------------------------

print("\nSources:\n")

for hit in results:
    print(
        f"- {hit.payload.get('source', 'unknown')} "
        f"(score={hit.score:.4f})"
    )
